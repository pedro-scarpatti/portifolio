---
interface Props {
  name: string;
  level: string;
  width: number;
}

const { name, level, width } = Astro.props;
---

<div>
  <div class="flex justify-between items-center mb-2">
    <span class="text-sm font-medium" style="color: var(--color-text-primary);">{name}</span>
    <span
      class="text-xs font-mono"
      style="color: var(--color-accent-green); opacity: 0.8;"
    >
      {level}
    </span>
  </div>
  <div class="skill-bar-track">
    <div
      class="skill-bar-fill"
      style={`width: ${width}%;`}
    ></div>
  </div>
</div>
